# Agent service config — TEMPLATE ONLY (committed). Never put real values here.
# Copy to .env (gitignored) and fill it in there:  cp .env.example .env

# Anthropic API key. During development you can use any non-empty placeholder —
# the agent runs in stub mode unless a real key (sk-ant-...) is provided.
ANTHROPIC_API_KEY=

# Supabase project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=

# Supabase secret (service-role) key. OPTIONAL for the current design: the agent
# verifies user JWTs via JWKS and does not write to the database. Leave blank
# unless/until the agent needs privileged DB access.
SUPABASE_SECRET_KEY=

# JWKS endpoint for verifying user JWTs (derived from SUPABASE_URL):
#   https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=
