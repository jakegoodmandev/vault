# Supabase CLI config — TEMPLATE ONLY (committed). Real values go in .env (gitignored).
# Used to link/push the local migrations to your hosted project:
#   cp .env.example .env   # then fill in .env, never this file

# Project ref = the subdomain of your project URL: https://<project-ref>.supabase.co
SUPABASE_PROJECT_REF=

# Database password (chosen when you created the project). Needed for `supabase db push`.
SUPABASE_DB_PASSWORD=

# Personal access token from https://supabase.com/dashboard/account/tokens
# Needed for non-interactive `supabase link`. Format: sbp_...
SUPABASE_ACCESS_TOKEN=
